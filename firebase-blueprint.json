{
  "entities": {
    "Course": {
      "title": "Course",
      "description": "Represents a course container.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["title"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Represents a lesson with content like slides, commands, and prompts.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "isPublished": { "type": "boolean" },
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "code": { "type": "string" },
              "language": { "type": "string" }
            }
          }
        },
        "prompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "enabledTabs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "urls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["courseId", "title"]
    },
    "Admin": {
      "title": "Admin",
      "description": "List of admin users.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Stores courses."
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Stores lessons belonging to a course."
    },
    "/admins/{userId}": {
      "schema": "Admin",
      "description": "Stores admin privileges."
    }
  }
}